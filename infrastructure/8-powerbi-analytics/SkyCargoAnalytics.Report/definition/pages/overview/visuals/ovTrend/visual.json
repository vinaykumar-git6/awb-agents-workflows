{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/1.0.0/schema.json",
  "name": "ovTrend",
  "position": { "x": 16, "y": 208, "z": 6, "width": 760, "height": 290, "tabOrder": 6 },
  "visual": {
    "visualType": "areaChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
