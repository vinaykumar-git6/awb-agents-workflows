            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": { "Measure": { "Expression": { "SourceRef": { "Entity": "awb_analytics" } }, "Property": "Total AWBs" } },
              "queryRef": "awb_analytics.Total AWBs",
              "nativeQueryRef": "Total AWBs"
            },
            {
              "field": { "Measure": { "Expression": { "SourceRef": { "Entity": "awb_analytics" } }, "Property": "Failed AWBs" } },
              "queryRef": "awb_analytics.Failed AWBs",
              "nativeQueryRef": "Failed AWBs"
            }
          ]
        }
      }
    },
    "objects": {
      "title": [
        { "properties": { "text": { "expr": { "Literal": { "Value": "'AWB volume over time'" } } } } }
      ]
    },
    "drillFilterOtherVisuals": true
  }
